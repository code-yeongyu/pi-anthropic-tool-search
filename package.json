{
	"name": "pi-anthropic-tool-search",
	"version": "0.1.0",
	"description": "Anthropic native tool-search policy extension for the pi coding agent. Conditionally injects Anthropic tool-search tools based on PI_ANTHROPIC_TOOL_SEARCH and appends tool-search guidance to the system prompt.",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/code-yeongyu/pi-anthropic-tool-search",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/code-yeongyu/pi-anthropic-tool-search.git"
	},
	"bugs": {
		"url": "https://github.com/code-yeongyu/pi-anthropic-tool-search/issues"
	},
	"keywords": [
		"pi",
		"pi-mono",
		"pi-coding-agent",
		"pi-extension",
		"coding-agent",
		"anthropic",
		"tool-search",
		"claude",
		"typescript"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md",
		"LICENSE",
		"NOTICE"
	],
	"scripts": {
		"build": "npm run typecheck",
		"test": "vitest --run",
		"test:watch": "vitest",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsgo --noEmit && biome check ."
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "^7.0.0-dev.20260501.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
